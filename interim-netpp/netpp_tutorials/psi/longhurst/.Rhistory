#' Find common (non-NA) grid points between MODIS and VIIRS fields
#'
#' This function identifies grid cells where both MODIS and VIIRS
#' beta and p-value fields are not NA, and returns the paired values
#' plus the number of common points.
#'
#' @param modis_beta  Numeric matrix/array of MODIS beta values.
#' @param viirs_beta Numeric matrix/array of VIIRS beta values.
#' @param modis_pval  Numeric matrix/array of MODIS p-values.
#' @param viirs_pval Numeric matrix/array of VIIRS p-values.
#'
#' @return A list with:
#' \describe{
#'   \item{beta_common}{List of two numeric vectors: MODIS and VIIRS beta at common points.}
#'   \item{pval_common}{List of two numeric vectors: MODIS and VIIRS p-values at common points.}
#'   \item{num_common}{Integer, number of grid points with non-NA values in both fields.}
#' }
#'
find_common_points <- function(modis_beta, viirs_beta, modis_pval, viirs_pval) {
mask <- !is.na(modis_beta) & !is.na(viirs_beta)
beta_common <- list(modis_beta[mask], viirs_beta[mask])
pval_common <- list(modis_pval[mask], viirs_pval[mask])
num_common <- sum(mask)
return(list(beta_common = beta_common, pval_common = pval_common, num_common = num_common))
}
#' Create a 2x2 contingency table of trend agreement
#'
#' This function builds a 2x2 contingency table showing the percentage of
#' common grid points where MODIS and NOAA-20 (or SNPP) trends are non-negative
#' (β >= 0) or negative (β < 0).
#'
#' @param beta_common List of two numeric vectors containing MODIS and
#'   NOAA-20 beta values at common (non-NA) grid points, typically from
#'   \code{find_common_points()}.
#' @param num_common Integer giving the number of common grid points.
#'
#' @return A 2x2 matrix of percentages, with MODIS trend classes as rows
#'   and NOAA-20 trend classes as columns.
#'
create_2x2_contingency_table <- function(beta_common, num_common) {
table <- matrix(0, 2, 2)
rownames(table) <- c("MODIS β >= 0", "MODIS β < 0")
colnames(table) <- c("NOAA-20 β >= 0", "NOAA-20 β < 0")
table[1, 1] <- sum(beta_common[[1]] >= 0 & beta_common[[2]] >= 0) / num_common * 100
table[1, 2] <- sum(beta_common[[1]] >= 0 & beta_common[[2]] < 0) / num_common * 100
table[2, 1] <- sum(beta_common[[1]] < 0 & beta_common[[2]] >= 0) / num_common * 100
table[2, 2] <- sum(beta_common[[1]] < 0 & beta_common[[2]] < 0) / num_common * 100
return(table)
}
#' Create a 3x3 contingency table of trend/significance agreement
#'
#' This function builds a 3x3 contingency table showing the percentage of
#' common grid points where MODIS and NOAA-20 (or SNPP) trends are classified as
#' non-significant, significantly non-negative (β >= 0), or significantly
#' negative (β < 0) based on a p-value threshold.
#'
#' @param beta_common List of two numeric vectors with MODIS and NOAA-20
#'   beta values at common (non-NA) grid points.
#' @param pval_common List of two numeric vectors with MODIS and NOAA-20
#'   p-values at the same common grid points.
#' @param num_common Integer giving the number of common grid points.
#' @param alpha Numeric p-value threshold used to define significance
#'   (default is 0.05).
#'
#' @return A 3x3 matrix of percentages, with MODIS classes as rows
#'   (n.s., β >= 0, β < 0) and NOAA-20 classes as columns.
#'
create_3x3_contingency_table <- function(beta_common, pval_common, num_common, alpha = 0.05) {
table <- matrix(0, 3, 3)
rownames(table) <- c("MODIS n.s.", "MODIS β >= 0", "MODIS β < 0")
colnames(table) <- c("NOAA-20 n.s.", "NOAA-20 β >= 0", "NOAA-20 β < 0")
ns_indices_1 <- which(pval_common[[1]] >= alpha)
ns_indices_2 <- which(pval_common[[2]] >= alpha)
table[1, 1] <- sum(ns_indices_1 %in% ns_indices_2) / num_common * 100
table[2, 1] <- sum(ns_indices_1 %in% which(pval_common[[2]] < alpha & beta_common[[2]] >= 0)) / num_common * 100
table[3, 1] <- sum(ns_indices_1 %in% which(pval_common[[2]] < alpha & beta_common[[2]] < 0)) / num_common * 100
table[1, 2] <- sum(ns_indices_2 %in% which(pval_common[[1]] < alpha & beta_common[[1]] >= 0)) / num_common * 100
table[1, 3] <- sum(ns_indices_2 %in% which(pval_common[[1]] < alpha & beta_common[[1]] < 0)) / num_common * 100
sig_indices_1 <- which(pval_common[[1]] < alpha)
sig_indices_2 <- which(pval_common[[2]] < alpha)
common_indices_sig1 <- sig_indices_1[sig_indices_1 %in% sig_indices_2]
common_indices_sig2 <- sig_indices_2[sig_indices_2 %in% sig_indices_1]
reshaped_data <- list(
beta_common[[1]][common_indices_sig1],
beta_common[[2]][common_indices_sig2]
)
table[2, 2] <- sum(reshaped_data[[1]] >= 0 & reshaped_data[[2]] >= 0) / num_common * 100
table[2, 3] <- sum(reshaped_data[[1]] >= 0 & reshaped_data[[2]] < 0) / num_common * 100
table[3, 2] <- sum(reshaped_data[[1]] < 0 & reshaped_data[[2]] >= 0) / num_common * 100
table[3, 3] <- sum(reshaped_data[[1]] < 0 & reshaped_data[[2]] < 0) / num_common * 100
return(table)
}
#' Compute Cohen's Kappa from a contingency table
#'
#' This function calculates Cohen's Kappa statistic from a contingency
#' table, returning the kappa value as a single number.
#'
#' @param contingency_table A matrix or table of observed agreement
#'   counts or percentages between two classifiers.
#'
#' @return Numeric value of Cohen's Kappa.
#'
compute_kappa <- function(contingency_table) {
kappa_result <- cohen.kappa(contingency_table)$kappa
return(kappa_result)
}
#' Plot a contingency table with Cohen's Kappa
#'
#' This function creates a heatmap-style plot of a contingency table and
#' displays Cohen's Kappa as text below the plot.
#'
#' @param table A matrix or table of values (e.g., percentages) to plot.
#' @param title Character string for the plot title.
#' @param kappa_value Numeric value of Cohen's Kappa to display under the plot.
#'
#' @return A grob object combining the contingency table plot and the
#'   Kappa annotation.
#'
plot_contingency_table <- function(table, title, kappa_value) {
df <- as.data.frame(as.table(table))
# Create the contingency table plot
p <- ggplot(df, aes(Var1, Var2, fill = Freq)) +
geom_tile() +
geom_text(aes(label = round(Freq, 1)), color = "white", size = 6) +
scale_fill_gradient(low = "lightblue", high = "darkblue") +
labs(title = title, fill = "Percentage", x = "", y = "") +
theme_minimal()
# Create a separate text grob for Kappa
kappa_text <- grid::textGrob(
label = paste("Cohen's Kappa:", round(kappa_value, 2)),
gp = grid::gpar(fontsize = 12, fontface = "bold")
)
# Arrange the plot and Kappa text below
full_plot <- gridExtra::grid.arrange(p, kappa_text, ncol = 1, heights = c(4, 0.5))
return(full_plot)
}
