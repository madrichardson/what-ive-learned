        :geospatial_lat_min = -90.f ;
        :geospatial_lon_max = 180.f ;
        :geospatial_lon_min = -180.f ;
        :latitude_step = 0.08333334f ;
        :longitude_step = 0.08333334f ;
        :spatialResolution = "9.28 km" ;
        :geospatial_lon_resolution = 0.083333f ;
        :geospatial_lat_resolution = 0.083333f ;
        :geospatial_lat_units = "degrees_north" ;
        :geospatial_lon_units = "degrees_east" ;
        :proj4_string = "+proj=eqc +lat_ts=0 +lat_0=0 +x_0=0 +y_0=0 +ellps=WGS84 +datum=WGS84 +units=m +no_defs +lon_0=0.000000" ;
        :summary = "The unbiased relative difference (Psi) between primary productivity (netPP) calculated using VIIRS NOAA-20 data and MODIS Aqua data. For each pixel, psi is calculated as netPP(viirs)- netPP(modis) divided by the mean of netPP(viirs) and netPP(modis) as described by Mélina et al. 2017. Primary productivity was calculated as described by Behrenfeld and Falkowski 1997. The data are a 10-year mean from Jan 2013 to Dec 2022 and at 9km resolution. Input data for primary productivity were obtained from NASA and included chlorophyll_a, sea surface temperature, and photosynthetically active radiation from either MODIS Aqua or VIIRS SNPP.." ;
        :title = "Pixel by pixel Psi, VIIRS NOAA-20 minus MODIS Aqua" ;
