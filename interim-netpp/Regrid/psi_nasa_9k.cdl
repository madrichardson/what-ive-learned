        psi:missing_value = -999.f ;
        psi:units = "1" ;

// global attributes:
        :cdm_data_type = "Grid" ;
        :map_projection = "geographic" ;
        :time_coverage_resolution = "PDM" ;
        :project = "NOAA CoastWatch Interim Primary Productivity" ;
        :latitude_units = "degrees_north" ;
        :longitude_units = "degrees_east" ;
        :northernmost_latitude = 90.f ;
        :southernmost_latitude = -90.f ;
        :westernmost_longitude = -180.f ;
        :easternmost_longitude = 180.f ;
